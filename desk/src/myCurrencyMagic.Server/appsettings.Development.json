{
  "Urls": "http://localhost:5034",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Api": {
    "ClientHeader": {
      "Name": "X-myCurrencyMagic-Client",
      "ExpectedValue": "myCurrencyMagic.Client"
    },
    "SupportedLanguages": [ "en", "de" ],
    "SupportedCurrencies": [ "USD" ]
  },
  "ServerLogging": {
    "FilePath": "logs/log-.txt",
    "RetainedFileCountLimit": 168,
    "FlushToDiskIntervalSeconds": 1
  }
}
