//
// Purpose: Manual HTTP request file for Visual Studio. It helps to test the local server endpoint
// by hand without extra tools.
// The request mirrors the API contract used by the client: local localhost URL, POST /convert,
// JSON body, and the required client header.
//

@myCurrencyMagic.Server_HostAddress = http://localhost:5034

POST {{myCurrencyMagic.Server_HostAddress}}/convert
Accept: application/json
Content-Type: application/json
X-myCurrencyMagic-Client: myCurrencyMagic.Client

{
  "language": "de",
  "currency": "USD",
  "amount": "1 234,56"
}

###
